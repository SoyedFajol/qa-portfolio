# Server-side secrets — set these in Vercel → Project → Settings → Environment Variables.
# NEVER commit real values. NEVER import these in frontend code.

# Google AI Studio key (free tier) — powers /api/chat and /api/generate-quiz
GEMINI_API_KEY=

# RapidAPI key with the JSearch API enabled (free tier) — powers /api/jobs
RAPIDAPI_KEY=
